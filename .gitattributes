# Auto detect text files and normalize line endings to LF
* text=auto

# Source code files
*.scala text eol=lf
*.pl text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.sbt text eol=lf
*.css text eol=lf
*.html text eol=lf

# Ensure shell scripts have LF line endings
*.sh eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.class binary
